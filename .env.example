# AI-Service Configuration Example

# App Settings
APP_NAME=AI-Service
DEBUG=false
LOG_LEVEL=INFO

# Backend Integration (IMPORTANT: Must match Backend settings)
BACKEND_JWT_SECRET=your-secret-key-here-change-in-production
BACKEND_CALLBACK_SECRET=shared-secret-key-for-hmac-verification

# JWT Settings
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_AUDIENCE=attendance-system
JWT_ISSUER=backend-service

# Face Detection
DETECTOR_CHECKPOINT=/path/to/yolov3_face_checkpoint.pth.tar
DETECTOR_DEVICE=cuda
DETECTOR_CONF_THRESHOLD=0.75
DETECTOR_NMS_THRESHOLD=0.4

# Face Recognition
RECOGNIZER_CHECKPOINT=/path/to/model_ir_se50.pth
RECOGNIZER_DEVICE=cuda
RECOGNIZER_THRESHOLD=1.5
RECOGNIZER_KNN_K=5
RECOGNIZER_MIN_CONFIDENCE=0.5

# Recognition Validation (Anti-premature detection)
# Số lần nhận diện tối thiểu để xác nhận (ví dụ: 3 lần trong 5 frame)
RECOGNITION_CONFIRMATION_THRESHOLD=3
# Số frame gần nhất để xem xét
RECOGNITION_WINDOW_SIZE=5
# Confidence score trung bình tối thiểu để xác nhận
RECOGNITION_MIN_AVG_CONFIDENCE=0.60
# Tỷ lệ nhận diện thành công tối thiểu (3/5 = 0.6)
RECOGNITION_MIN_SUCCESS_RATE=0.60
# Thời gian debounce để tránh gửi callback lặp lại (giây)
RECOGNITION_DEBOUNCE_SECONDS=30

# Storage
EMBEDDING_DIR=/path/to/embeddings
DATABASE_DIR=/path/to/database

# Callback Settings
CALLBACK_MAX_RETRIES=3
CALLBACK_RETRY_DELAY=1.0

# S3/MinIO (optional)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
