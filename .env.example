# =============================================================================
# AI Service - Environment Configuration Template
# =============================================================================
# Sao chép file này thành .env và điền các giá trị thực tế.
# KHÔNG commit file .env lên Git!
# =============================================================================

# App settings
APP_NAME=AI-Service
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO
ENVIRONMENT=development

# Server settings
HOST=0.0.0.0
PORT=8069

# -------------------------
# Backend Integration (BẮT BUỘC)
# Must match Backend SECRET_KEY and AI_SERVICE_SECRET
# -------------------------
BACKEND_JWT_SECRET=your-backend-jwt-secret-here
BACKEND_CALLBACK_SECRET=your-backend-ai-service-secret-here

# -------------------------
# PostgreSQL (BẮT BUỘC)
# -------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_attendance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here

# -------------------------
# AWS S3 (Tùy chọn - để trống nếu không dùng)
# -------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_MODEL_BUCKET=

# -------------------------
# Model Paths (Điền đường dẫn đến model trên máy)
# -------------------------
EMBEDDING_DIR=
DETECTOR_CHECKPOINT=/path/to/yolov3_face_checkpoint.pth.tar
RECOGNIZER_CHECKPOINT=/path/to/model_ir_se50.pth
ANTISPOOFING_CHECKPOINT=/path/to/checkpoint.pt

# -------------------------
# Model Device settings
# -------------------------
MODEL_DEVICE=cuda
ANTISPOOFING_DEVICE=cuda

# -------------------------
# Memory Optimization (Tùy chọn)
# -------------------------
MEMORY_GPU_THRESHOLD=0.85
MEMORY_CLEANUP_INTERVAL=50
MEMORY_MAX_FACES_PER_FRAME=10
MEMORY_MAX_IMAGE_SIZE=1280
MEMORY_MAX_SPOOF_CROPS=50
MEMORY_AGGRESSIVE_GC=true